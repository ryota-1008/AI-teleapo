# ===== サーバー基本設定 =====
PORT=4000
# 認証ミドルウェアの箱(13章)。今は off。複数人化のとき on にして APP_PASSWORD を設定する
AUTH_ENABLED=false
APP_PASSWORD=

# ===== Twilio (Phase 1 手動モード / Phase 2 で使用) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
# 手動モード発信用の発信者番号(+81形式)
TWILIO_CALLER_ID=

# ===== ElevenLabs (Phase 2 AIモードで使用) =====
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
# post-call webhook の署名検証用シークレット(14-3)
ELEVENLABS_WEBHOOK_SECRET=
