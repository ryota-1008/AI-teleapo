# ===== Supabase / Postgres (Prisma) =====
# Supabaseダッシュボード → Project Settings → Database → Connection string
# DATABASE_URL: アプリ実行用（Connection pooling / Transaction, port 6543, ?pgbouncer=true）
# DIRECT_URL : マイグレーション用（Direct connection, port 5432）
DATABASE_URL=
DIRECT_URL=

# ===== 認証(任意・複数人化時) =====
APP_PASSWORD=

# ===== Twilio (手動モード) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=

# ===== ElevenLabs (AIモード) =====
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
